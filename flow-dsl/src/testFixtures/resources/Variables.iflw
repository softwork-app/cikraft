<?xml version="1.0" encoding="UTF-8"?><bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions">
    <bpmn2:collaboration id="Collaboration" name="Default Collaboration">
        <bpmn2:extensionElements>
            <ifl:property>
                <key>namespaceMapping</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>httpSessionHandling</key>
                <value>None</value>
            </ifl:property>
            <ifl:property>
                <key>accessControlMaxAge</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>returnExceptionToSender</key>
                <value>false</value>
            </ifl:property>
            <ifl:property>
                <key>log</key>
                <value>All events</value>
            </ifl:property>
            <ifl:property>
                <key>corsEnabled</key>
                <value>false</value>
            </ifl:property>
            <ifl:property>
                <key>exposedHeaders</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>componentVersion</key>
                <value>1.2</value>
            </ifl:property>
            <ifl:property>
                <key>allowedHeaderList</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>ServerTrace</key>
                <value>false</value>
            </ifl:property>
            <ifl:property>
                <key>allowedOrigins</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>accessControlAllowCredentials</key>
                <value>false</value>
            </ifl:property>
            <ifl:property>
                <key>allowedHeaders</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>allowedMethods</key>
                <value/>
            </ifl:property>
            <ifl:property>
                <key>cmdVariantUri</key>
                <value>ctype::IFlowVariant/cname::IFlowConfiguration/version::1.2.4</value>
            </ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:participant id="Participant" ifl:type="EndpointSender" name="Sender">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>ifl:type</key>
                    <value>EndpointSender</value>
                </ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_Process" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow" name="DataStore" sourceRef="Participant" targetRef="StartEvent">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>ComponentType</key>
                    <value>DataStoreConsumer</value>
                </ifl:property>
                <ifl:property>
                    <key>Description</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>visibility</key>
                    <value>global</value>
                </ifl:property>
                <ifl:property>
                    <key>MaxRetryInterval</key>
                    <value>60</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentNS</key>
                    <value>sap</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.0</value>
                </ifl:property>
                <ifl:property>
                    <key>ExponentialBackoff</key>
                    <value>1</value>
                </ifl:property>
                <ifl:property>
                    <key>Name</key>
                    <value>DataStore</value>
                </ifl:property>
                <ifl:property>
                    <key>storageName</key>
                    <value>DS_FOO</value>
                </ifl:property>
                <ifl:property>
                    <key>TransportProtocolVersion</key>
                    <value>1.0.0</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentSWCVName</key>
                    <value>external</value>
                </ifl:property>
                <ifl:property>
                    <key>system</key>
                    <value>Sender</value>
                </ifl:property>
                <ifl:property>
                    <key>TransportProtocol</key>
                    <value>JDBC</value>
                </ifl:property>
                <ifl:property>
                    <key>PollDelay</key>
                    <value>300</value>
                </ifl:property>
                <ifl:property>
                    <key>RetryInterval</key>
                    <value>1</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::AdapterVariant/cname::sap:DataStoreConsumer/tp::JDBC/mp::None/direction::Sender/version::1.0.0</value>
                </ifl:property>
                <ifl:property>
                    <key>MessageProtocol</key>
                    <value>None</value>
                </ifl:property>
                <ifl:property>
                    <key>MessageProtocolVersion</key>
                    <value>1.0.0</value>
                </ifl:property>
                <ifl:property>
                    <key>ComponentSWCVId</key>
                    <value>1.0.0</value>
                </ifl:property>
                <ifl:property>
                    <key>file_lock_timeout</key>
                    <value>10</value>
                </ifl:property>
                <ifl:property>
                    <key>direction</key>
                    <value>Sender</value>
                </ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:messageFlow>
    </bpmn2:collaboration>
    <bpmn2:process id="Process" name="Integration Process">
        <bpmn2:extensionElements>
            <ifl:property>
                <key>transactionTimeout</key>
                <value>30</value>
            </ifl:property>
            <ifl:property>
                <key>componentVersion</key>
                <value>1.2</value>
            </ifl:property>
            <ifl:property>
                <key>cmdVariantUri</key>
                <value>ctype::FlowElementVariant/cname::IntegrationProcess/version::1.2.1</value>
            </ifl:property>
            <ifl:property>
                <key>transactionalHandling</key>
                <value>Not Required</value>
            </ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:startEvent id="StartEvent" name="Start">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.0</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::MessageStartEvent/version::1.0</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:messageEventDefinition/>
            <bpmn2:outgoing>SequenceFlow_Start</bpmn2:outgoing>
        </bpmn2:startEvent>
        <bpmn2:callActivity id="Write0" name="Write 1">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>storageName</key>
                    <value>DS_FOO</value>
                </ifl:property>
                <ifl:property>
                    <key>visibility</key>
                    <value>global</value>
                </ifl:property>
                <ifl:property>
                    <key>messageId</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>alert</key>
                    <value>2</value>
                </ifl:property>
                <ifl:property>
                    <key>expire</key>
                    <value>30</value>
                </ifl:property>
                <ifl:property>
                    <key>encrypt</key>
                    <value>true</value>
                </ifl:property>
                <ifl:property>
                    <key>override</key>
                    <value>true</value>
                </ifl:property>
                <ifl:property>
                    <key>includeMessageHeaders</key>
                    <value>false</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.7</value>
                </ifl:property>
                <ifl:property>
                    <key>activityType</key>
                    <value>DBstorage</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::put/version::1.7.1</value>
                </ifl:property>
                <ifl:property>
                    <key>operation</key>
                    <value>put</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_Start</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_0</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="Get1" name="Get 1">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>storageName</key>
                    <value>DS_FOO</value>
                </ifl:property>
                <ifl:property>
                    <key>visibility</key>
                    <value>local</value>
                </ifl:property>
                <ifl:property>
                    <key>dataStoreId</key>
                    <value>sdf</value>
                </ifl:property>
                <ifl:property>
                    <key>delete</key>
                    <value>false</value>
                </ifl:property>
                <ifl:property>
                    <key>stopOnMissingEntry</key>
                    <value>true</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.7</value>
                </ifl:property>
                <ifl:property>
                    <key>activityType</key>
                    <value>DBstorage</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::get/version::1.7.1</value>
                </ifl:property>
                <ifl:property>
                    <key>operation</key>
                    <value>get</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_0</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_1</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="Select2" name="Select 1">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>storageName</key>
                    <value>DS_FOO</value>
                </ifl:property>
                <ifl:property>
                    <key>visibility</key>
                    <value>local</value>
                </ifl:property>
                <ifl:property>
                    <key>maxresults</key>
                    <value>1</value>
                </ifl:property>
                <ifl:property>
                    <key>delete</key>
                    <value>false</value>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.7</value>
                </ifl:property>
                <ifl:property>
                    <key>activityType</key>
                    <value>DBstorage</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::select/version::1.7.1</value>
                </ifl:property>
                <ifl:property>
                    <key>operation</key>
                    <value>select</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_1</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_2</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="Delete3" name="Delete 1">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>storageName</key>
                    <value>DS_FOO</value>
                </ifl:property>
                <ifl:property>
                    <key>visibility</key>
                    <value>local</value>
                </ifl:property>
                <ifl:property>
                    <key>messageId</key>
                    <value/>
                </ifl:property>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.7</value>
                </ifl:property>
                <ifl:property>
                    <key>activityType</key>
                    <value>DBstorage</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::delete/version::1.7.1</value>
                </ifl:property>
                <ifl:property>
                    <key>operation</key>
                    <value>delete</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_2</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_End</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:endEvent id="EndEvent" name="End">
            <bpmn2:extensionElements>
                <ifl:property>
                    <key>componentVersion</key>
                    <value>1.1</value>
                </ifl:property>
                <ifl:property>
                    <key>cmdVariantUri</key>
                    <value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value>
                </ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_End</bpmn2:incoming>
        </bpmn2:endEvent>
        <bpmn2:sequenceFlow id="SequenceFlow_Start" sourceRef="StartEvent" targetRef="Write0"/>
        <bpmn2:sequenceFlow id="SequenceFlow_0" sourceRef="Write0" targetRef="Get1"/>
        <bpmn2:sequenceFlow id="SequenceFlow_1" sourceRef="Get1" targetRef="Select2"/>
        <bpmn2:sequenceFlow id="SequenceFlow_2" sourceRef="Select2" targetRef="Delete3"/>
        <bpmn2:sequenceFlow id="SequenceFlow_End" sourceRef="Delete3" targetRef="EndEvent"/>
    </bpmn2:process>
    <bpmndi:BPMNDiagram id="BPMNDiagram" name="Default Collaboration Diagram">
        <bpmndi:BPMNPlane bpmnElement="Collaboration" id="BPMNPlane">
            <bpmndi:BPMNShape bpmnElement="Participant" id="BPMNShape_Participant">
                <dc:Bounds height="140" width="100" x="0" y="0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="StartEvent" id="BPMNShape_StartEvent">
                <dc:Bounds height="40" width="40" x="200" y="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Write0" id="BPMNShape_Write0">
                <dc:Bounds height="60" width="100" x="300" y="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Get1" id="BPMNShape_Get1">
                <dc:Bounds height="60" width="100" x="460" y="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Select2" id="BPMNShape_Select2">
                <dc:Bounds height="60" width="100" x="620" y="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Delete3" id="BPMNShape_Delete3">
                <dc:Bounds height="60" width="100" x="780" y="40"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent" id="BPMNShape_EndEvent">
                <dc:Bounds height="40" width="40" x="940" y="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_Process" id="BPMNShape_Participant_Process">
                <dc:Bounds height="140" width="1090" x="150" y="0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_Start" id="BPMNEdge_SequenceFlow_Start" sourceElement="BPMNShape_StartEvent" targetElement="BPMNShape_Write0">
                <di:waypoint x="220" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="300" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_0" id="BPMNEdge_SequenceFlow_0" sourceElement="BPMNShape_Write0" targetElement="BPMNShape_Get1">
                <di:waypoint x="380" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="460" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="BPMNEdge_SequenceFlow_1" sourceElement="BPMNShape_Get1" targetElement="BPMNShape_Select2">
                <di:waypoint x="540" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="620" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_2" id="BPMNEdge_SequenceFlow_2" sourceElement="BPMNShape_Select2" targetElement="BPMNShape_Delete3">
                <di:waypoint x="700" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="780" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_End" id="BPMNEdge_SequenceFlow_End" sourceElement="BPMNShape_Delete3" targetElement="BPMNShape_EndEvent">
                <di:waypoint x="860" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="940" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow" id="BPMNEdge_MessageFlow" sourceElement="BPMNShape_Participant" targetElement="BPMNShape_StartEvent">
                <di:waypoint x="90" xsi:type="dc:Point" y="70"/>
                <di:waypoint x="220" xsi:type="dc:Point" y="70"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</bpmn2:definitions>
