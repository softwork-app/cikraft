<?xml version='1.0' encoding='UTF-8' ?>
<ProxyEndPoint xmlns="http://www.sap.com/apimgmt" default="true">
    <name>default</name>
    <base_path>/foo/shop2</base_path>
    <routeRules>
        <routeRule>
            <name>default</name>
            <targetEndPointName>default</targetEndPointName>
            <sequence>1</sequence>
        </routeRule>
    </routeRules>
    <preFlow>
        <name>PreFlow</name>
        <request>
            <isRequest>true</isRequest>
            <steps>
                <step>
                    <policy_name>readCachedKeys</policy_name>
                    <sequence>1</sequence>
                </step>
                <step>
                    <policy_name>readJWTKeys</policy_name>
                    <condition>lookupcache.readCachedKeys.cachehit == "false"</condition>
                    <sequence>2</sequence>
                </step>
                <step>
                    <policy_name>cacheJWTKeys</policy_name>
                    <condition>lookupcache.readCachedKeys.cachehit == "false"</condition>
                    <sequence>3</sequence>
                </step>
                <step>
                    <policy_name>verifyJWT</policy_name>
                    <sequence>4</sequence>
                </step>
                <step>
                    <policy_name>Spike</policy_name>
                    <sequence>5</sequence>
                </step>
                <step>
                    <policy_name>RateLimit</policy_name>
                    <sequence>6</sequence>
                </step>
                <step>
                    <policy_name>Add429</policy_name>
                    <condition>(jwt.verifyJWT.valid == "false") OR (ratelimit.RateLimit.failed == "true")</condition>
                    <sequence>7</sequence>
                </step>
            </steps>
        </request>
    </preFlow>
    <postFlow>
        <name>PostFlow</name>
        <response>
            <isRequest>false</isRequest>
            <steps>
                <step>
                    <policy_name>MMM</policy_name>
                    <sequence>1</sequence>
                </step>
            </steps>
        </response>
    </postFlow>
</ProxyEndPoint>
